ErrorDocument 404 /404.html

<IfModule mod_headers.c>
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  Header always set Content-Security-Policy "default-src 'self'; img-src 'self' data: https://*.simpleshop.cz https://www.google-analytics.com https://www.googletagmanager.com https://i.ytimg.com; script-src 'self' 'unsafe-inline' https://form.simpleshop.cz https://*.simpleshop.cz https://www.googletagmanager.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net https://form.simpleshop.cz https://*.simpleshop.cz; font-src 'self' https://fonts.gstatic.com https://cdn.jsdelivr.net; connect-src 'self' https://*.simpleshop.cz https://www.google-analytics.com https://region1.google-analytics.com https://www.googletagmanager.com; frame-src 'self' https://*.simpleshop.cz https://www.youtube.com https://www.youtube-nocookie.com; base-uri 'self'; form-action 'self' https://*.simpleshop.cz; upgrade-insecure-requests"
</IfModule>
